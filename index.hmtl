<!DOCTYPE html>

<html lang="ar" dir="rtl">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover">
<title>X-RAY Platform - Template</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=IBM+Plex+Sans+Arabic:wght@300;400;600;700;800&family=Space+Mono:wght@400;700&display=swap" rel="stylesheet">
<style>
:root {
  --blue: #0A84FF; --green: #30D158; --red: #FF453A;
  --bg: #000000; --glass: rgba(28,28,30,0.80);
  --glass-border: rgba(255,255,255,0.09); --glass-hover: rgba(10,132,255,0.30);
  --text: #FFFFFF; --muted: rgba(255,255,255,0.40);
  --shadow: 0 20px 60px rgba(0,0,0,0.55);
}
[data-theme="light"] {
  --bg: #F2F2F7; --glass: rgba(255,255,255,0.78);
  --glass-border: rgba(0,0,0,0.07); --glass-hover: rgba(10,132,255,0.25);
  --text: #000000; --muted: rgba(0,0,0,0.38);
  --shadow: 0 20px 60px rgba(0,0,0,0.10);
}
*{box-sizing:border-box;margin:0;padding:0;}
body{
  background:var(--bg);
  background-image:
    radial-gradient(ellipse 90% 50% at 50% -5%, rgba(10,132,255,0.28), transparent),
    radial-gradient(ellipse 40% 30% at 85% 85%, rgba(48,209,88,0.07), transparent);
  color:var(--text); font-family:'IBM Plex Sans Arabic',sans-serif;
  min-height:100vh; display:flex; flex-direction:column; align-items:center;
  padding:14px 14px 90px; transition:background .4s,color .4s;
}
.dynamic-island {
  position:fixed; top:12px; left:50%; transform:translateX(-50%);
  z-index:1000; display:flex; align-items:center; gap:8px;
  background:#1c1c1e; border-radius:22px; padding:8px 18px;
  box-shadow:0 8px 24px rgba(0,0,0,0.6); cursor:pointer;
  text-decoration:none; transition:all 0.3s cubic-bezier(0.4,0,0.2,1);
  backdrop-filter:blur(20px); -webkit-backdrop-filter:blur(20px);
  border:1px solid rgba(255,255,255,0.1); -webkit-tap-highlight-color:transparent;
}
.dynamic-island:active{transform:translateX(-50%) scale(0.96);background:#2c2c2e;}
.dynamic-island .di-icon{width:18px;height:18px;flex-shrink:0;fill:#24A1DE;}
.dynamic-island .di-text{font-weight:700;font-size:0.82rem;color:#ffffff;letter-spacing:0.5px;white-space:nowrap;}

.glass{background:var(–glass);backdrop-filter:blur(32px) saturate(200%);-webkit-backdrop-filter:blur(32px) saturate(200%);border:1px solid var(–glass-border);border-radius:22px;box-shadow:var(–shadow);}
.header{width:min(500px,100%);padding:13px 18px;display:flex;justify-content:space-between;align-items:center;margin-bottom:16px;margin-top:8px;}
.logo{font-family:‘Space Mono’,monospace;font-size:.88rem;font-weight:700;letter-spacing:2px;color:var(–blue);}
.logo b{color:var(–text);}
.toggle-row{display:flex;align-items:center;gap:8px;}
.toggle-lbl{font-size:.62rem;font-weight:700;color:var(–muted);letter-spacing:1px;}
.ios-sw{width:51px;height:29px;background:#3a3a3c;border-radius:15px;position:relative;cursor:pointer;transition:background .3s;}
[data-theme=“light”] .ios-sw{background:#e5e5ea;}
.ios-sw::after{content:’’;position:absolute;top:3px;left:3px;width:23px;height:23px;background:#fff;border-radius:50%;transition:transform .3s cubic-bezier(.4,0,.2,1);box-shadow:0 2px 6px rgba(0,0,0,.3);}
[data-theme=“light”] .ios-sw::after{transform:translateX(22px);}

.screen{width:min(500px,100%);display:none;}
.screen.active{display:block;}
.sec-label{font-size:.65rem;font-weight:700;color:var(–muted);letter-spacing:2px;text-transform:uppercase;margin:20px 0 10px 4px;}
.lec-card{padding:16px 18px;margin-bottom:9px;display:flex;align-items:center;gap:14px;cursor:pointer;position:relative;overflow:hidden;transition:border-color .2s,transform .15s,box-shadow .2s;}
.lec-num{width:44px;height:44px;border-radius:11px;background:rgba(10,132,255,.12);border:1px solid rgba(10,132,255,.22);display:flex;align-items:center;justify-content:center;font-family:‘Space Mono’,monospace;font-size:.72rem;font-weight:700;color:var(–blue);flex-shrink:0;}
.lec-body{flex:1;}
.lec-name{font-size:.93rem;font-weight:700;margin-bottom:3px;}
.lec-count{font-size:.72rem;color:var(–muted);}

.progress-wrap{margin-bottom:14px;padding:14px 18px;}
.prog-top{display:flex;justify-content:space-between;align-items:center;margin-bottom:8px;}
.prog-lec{font-size:.72rem;font-weight:700;color:var(–blue);letter-spacing:.5px;}
.prog-bar{height:4px;background:rgba(255,255,255,.08);border-radius:4px;overflow:hidden;}
.prog-fill{height:100%;background:var(–blue);border-radius:4px;transition:width .4s cubic-bezier(.4,0,.2,1);width:0%;}

.quiz-card{padding:22px 20px;margin-bottom:10px;}
.q-text{font-size:1.0rem;font-weight:700;line-height:1.7;text-align:center;margin-bottom:16px;}
.trans-row{display:grid;grid-template-columns:1fr 1fr;gap:8px;margin-bottom:10px;}
.btn-tr{background:rgba(10,132,255,.08);border:1px solid rgba(10,132,255,.18);color:var(–blue);padding:8px;border-radius:10px;font-size:.78rem;font-weight:700;cursor:pointer;font-family:‘IBM Plex Sans Arabic’,sans-serif;}
.opt{padding:14px 16px;border-radius:14px;background:rgba(255,255,255,.04);border:1px solid var(–glass-border);cursor:pointer;margin-bottom:8px;display:flex;align-items:center;gap:12px;}
.opt-letter{width:28px;height:28px;border-radius:7px;background:rgba(255,255,255,0.08);display:flex;align-items:center;justify-content:center;font-family:‘Space Mono’,monospace;font-size:.72rem;font-weight:700;color:var(–blue);flex-shrink:0;}
.opt.correct{background:rgba(48,209,88,.15);border-color:rgba(48,209,88,.5);}
.opt.wrong{background:rgba(255,69,58,.15);border-color:rgba(255,69,58,.5);}
.opt.correct .opt-letter{background:rgba(48,209,88,.3);color:#30D158;}
.opt.wrong .opt-letter{background:rgba(255,69,58,.3);color:#FF453A;}
.next-btn{width:100%;padding:15px;background:var(–blue);color:#fff;border:none;border-radius:14px;font-family:‘IBM Plex Sans Arabic’,sans-serif;font-weight:700;font-size:1rem;cursor:pointer;display:none;margin-top:10px;}
.back-btn{width:100%;padding:12px;background:transparent;color:var(–muted);border:1px solid var(–glass-border);border-radius:14px;font-family:‘IBM Plex Sans Arabic’,sans-serif;font-weight:700;font-size:.9rem;cursor:pointer;margin-bottom:12px;}

.result-card{padding:30px 20px;text-align:center;}
.result-score{font-size:3rem;font-weight:800;color:var(–blue);font-family:‘Space Mono’,monospace;}
.result-label{font-size:.9rem;color:var(–muted);margin-top:6px;margin-bottom:20px;}
.restart-btn{width:100%;padding:15px;background:var(–blue);color:#fff;border:none;border-radius:14px;font-family:‘IBM Plex Sans Arabic’,sans-serif;font-weight:700;font-size:1rem;cursor:pointer;}

.empty-state{padding:40px 20px;text-align:center;color:var(–muted);font-size:0.9rem;}

@keyframes fadeUp{from{opacity:0;transform:translateY(16px)}to{opacity:1;transform:translateY(0)}}
.quiz-card, .lec-card {animation:fadeUp .35s ease both;}
</style>

</head>
<body data-theme="dark">

<a href="https://t.me/XrayB1" target="_blank" class="dynamic-island">
  <svg class="di-icon" viewBox="0 0 24 24"><path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm4.64 6.8c-.15 1.58-.8 5.42-1.13 7.19-.14.75-.42 1-.68 1.03-.58.05-1.02-.38-1.58-.75-.88-.58-1.38-.94-2.23-1.5-.99-.65-.35-1.01.22-1.59.15-.15 2.71-2.48 2.76-2.69a.2.2 0 00-.05-.18c-.06-.05-.14-.03-.21-.02-.09.02-1.49.95-4.22 2.79-.4.27-.76.41-1.08.4-.36-.01-1.04-.2-1.55-.37-.63-.2-1.12-.31-1.08-.66.02-.18.27-.36.74-.55 2.92-1.27 4.86-2.11 5.83-2.51 2.78-1.16 3.35-1.36 3.73-1.36.08 0 .27.02.39.12.1.08.13.19.14.27-.01.06.01.24 0 .38z"/></svg>
  <span class="di-text">قناة X-RAY على التليجرام</span>
</a>

<div class="header glass">
  <div class="logo">X<b>-RAY</b> <span style="color:var(--muted);font-size:.7rem;letter-spacing:1px;">PLATFORM</span></div>
  <div class="toggle-row">
    <span class="toggle-lbl">MODE</span>
    <div class="ios-sw" onclick="toggleMode()"></div>
  </div>
</div>

<div id="screen-home" class="screen active">
  <div class="sec-label">المحاضرات المتاحة</div>
  <div id="lectures-list"></div>
</div>

<div id="screen-quiz" class="screen">
  <button class="back-btn" onclick="goHome()">← العودة للمحاضرات</button>
  <div class="progress-wrap glass">
    <div class="prog-top">
      <span class="prog-lec" id="prog-lec-name">جاري التحميل...</span>
      <span class="prog-count" id="prog-count">0/0</span>
    </div>
    <div class="prog-bar"><div class="prog-fill" id="prog-fill"></div></div>
  </div>
  <div class="quiz-card glass" id="quiz-card">
    <div class="q-text" id="q-text">نص السؤال سيظهر هنا</div>
    <div class="trans-row">
      <button class="btn-tr" onclick="translateQuestion()">🌐 ترجمة السؤال</button>
      <button class="btn-tr" onclick="translateOptions()">🌐 ترجمة الخيارات</button>
    </div>
    <div id="opts-wrap"></div>
    <button id="next-btn" class="next-btn" onclick="nextQuestion()">السؤال التالي ←</button>
  </div>
</div>

<div id="screen-result" class="screen">
  <div class="result-card glass">
    <div class="result-score" id="result-score">0/0</div>
    <div class="result-label">نتيجتك في هذه المحاضرة</div>
    <button class="restart-btn" onclick="goHome()">العودة للمحاضرات</button>
  </div>
</div>

<script>
const QUESTIONS_DATA = [
  {
    lecture: 1,
    title: "X-Ray Machine System & Operating Console",
    questions: [
      {
        q: "What is the primary medical use of an X-ray machine?",
        opts: ["To measure blood pressure", "To acquire images of internal structures of living organisms", "To perform surgical operations", "To measure body temperature"],
        ans: 1
      },
      {
        q: "What type of material is the patient examination couch ideally made of to reduce radiation dose?",
        opts: ["Steel", "Wood", "Carbon fiber", "Aluminum"],
        ans: 2
      },
      {
        q: "Which X-ray system type is described as stationary, high-power, and floor or ceiling-mounted?",
        opts: ["Mobile X-ray system", "Portable X-ray machine", "Fixed X-ray system", "C-arm system"],
        ans: 2
      },
      {
        q: "A radiographer needs to image a patient in the ICU ward without moving the patient to the radiology department. Which system type is most appropriate?",
        opts: ["Fixed X-ray system", "Mobile X-ray system", "DEXA scanner", "Mammography system"],
        ans: 1
      },
      {
        q: "Which of the following correctly lists the three principal parts of every X-ray machine?",
        opts: ["Cathode, anode, glass envelope", "Control console, high-voltage generator, X-ray tube", "Filament, focusing cup, target", "Rectifier, transformer, timer"],
        ans: 1
      },
      {
        q: "The operating console is described as the technician's 'cockpit' because it allows control of:",
        opts: ["Only kVp and mA", "kVp, mA, and exposure time", "Only exposure time", "Only the X-ray tube position"],
        ans: 1
      },
      {
        q: "Most X-ray machines are designed to operate on which power source voltage?",
        opts: ["110 V", "380 V", "220 V", "440 V"],
        ans: 2
      },
      {
        q: "What is the function of the Line Voltage Compensator?",
        opts: ["Increases kVp to maximum", "Compensates incoming voltage to maintain a constant 220 V during exposure", "Controls the filament temperature", "Measures the mAs automatically"],
        ans: 1
      },
      {
        q: "Higher kilovoltage results in which of the following?",
        opts: ["Longer wavelength X-rays and slower electrons", "Shorter wavelength X-rays and faster electrons", "Lower energy X-rays", "Reduced penetration of the X-ray beam"],
        ans: 1
      },
      {
        q: "Which factor primarily affects the quantity of X-rays produced?",
        opts: ["kVp", "mAs", "Filtration", "SID"],
        ans: 1
      },
      {
        q: "Which type of exposure timer is considered the most accurate and most expensive?",
        opts: ["Mechanical timer", "Synchronous timer", "Electronic timer", "mAs timer"],
        ans: 2
      },
      {
        q: "A technologist wants the exposure to terminate automatically when the image receptor has received sufficient radiation. Which timer type achieves this?",
        opts: ["Mechanical timer", "Synchronous timer", "mAs timer", "Automatic exposure control (AEC) timer"],
        ans: 3
      },
      {
        q: "The mAs timer terminates exposure when:",
        opts: ["A capacitor is fully charged", "The desired product of mA and time is attained", "The synchronous motor completes one revolution", "The filament reaches maximum temperature"],
        ans: 1
      },
      {
        q: "Which X-ray system provides real-time, continuous X-ray imaging?",
        opts: ["Mammography system", "DEXA scanner", "Fluoroscopy system", "Portable X-ray machine"],
        ans: 2
      },
      {
        q: "Which system is specifically designed for breast imaging using low-dose X-rays?",
        opts: ["C-arm system", "U-arm system", "Mammography system", "Dental panoramic system"],
        ans: 2
      }
    ]
  },
  {
    lecture: 2,
    title: "High Voltage Generators",
    questions: [
      {
        q: "What is the primary function of the high voltage generator (HVG) in an X-ray system?",
        opts: ["To cool the X-ray tube", "To convert low-voltage input into high-voltage energy to accelerate electrons", "To control patient positioning", "To process the digital image"],
        ans: 1
      },
      {
        q: "The autotransformer operates on which principle?",
        opts: ["Mutual induction", "Self-induction", "Electromagnetic radiation", "Photoelectric effect"],
        ans: 1
      },
      {
        q: "The high-voltage transformer is a step-up transformer because:",
        opts: ["The primary voltage is greater than the secondary voltage", "The number of secondary windings is greater than the number of primary windings", "It converts DC to AC", "It uses self-induction principle"],
        ans: 1
      },
      {
        q: "The turns ratio of the high-voltage transformer is typically between:",
        opts: ["10 and 100", "100 and 300", "500 and 1000", "1000 and 5000"],
        ans: 2
      },
      {
        q: "Rectification is needed in X-ray tubes because:",
        opts: ["X-ray tubes require alternating current", "X-ray tubes must be provided with direct current", "Transformers only work with DC", "Rectification increases the kVp"],
        ans: 1
      },
      {
        q: "Half-wave rectification uses how many diodes?",
        opts: ["One diode", "Two diodes", "Four diodes", "Six diodes"],
        ans: 1
      },
      {
        q: "Full-wave rectification contains at least how many diodes, and what does it achieve?",
        opts: ["Two diodes; removes the positive half-cycle", "Four diodes; reverses the negative half-cycle so positive voltage always directs across the tube", "Six diodes; doubles the kVp", "Eight diodes; eliminates all voltage ripple"],
        ans: 1
      },
      {
        q: "A single-phase, full-wave rectified generator produces how many pulsations per second and what percentage voltage ripple?",
        opts: ["60 pulsations, 50% ripple", "120 pulsations, 100% ripple", "360 pulsations, 13% ripple", "720 pulsations, 3% ripple"],
        ans: 1
      },
      {
        q: "A six-pulse three-phase generator reduces voltage ripple to approximately:",
        opts: ["100%", "50%", "13%", "1%"],
        ans: 2
      },
      {
        q: "A 12-pulse three-phase generator reduces voltage ripple to approximately:",
        opts: ["13%", "6%", "3%", "Less than 1%"],
        ans: 2
      },
      {
        q: "Which generator type has a voltage ripple of less than 1% and the shortest exposure time?",
        opts: ["Single-phase generator", "Three-phase six-pulse generator", "Three-phase twelve-pulse generator", "High-frequency generator"],
        ans: 3
      },
      {
        q: "High-frequency generators increase the standard frequency from 60 Hz to approximately:",
        opts: ["120 Hz", "500 Hz", "500 kHz", "1 MHz"],
        ans: 2
      },
      {
        q: "Which circuit component of the X-ray machine includes the Line Voltage Compensator, Autotransformer, and Exposure Timer?",
        opts: ["Secondary circuit", "Filament circuit", "Primary circuit", "Rectifier circuit"],
        ans: 2
      },
      {
        q: "The filament step-down transformer decreases voltage to and increases amperage to:",
        opts: ["5-10 V and 1-2 A", "10-12 V and 3-5 A", "20-30 V and 6-8 A", "50 V and 10 A"],
        ans: 1
      },
      {
        q: "Which waveform type produces the largest amount of low-energy soft X-rays absorbed by the patient?",
        opts: ["High-frequency waveform", "Three-phase waveform", "Single-phase waveform with 100% ripple", "Constant potential waveform"],
        ans: 2
      },
      {
        q: "For the same technical factors (kVp, mA), which generator type produces the highest quantity of photons?",
        opts: ["Single-phase generator", "Three-phase six-pulse generator", "Three-phase twelve-pulse generator", "High-frequency generator"],
        ans: 3
      }
    ]
  },
  {
    lecture: 3,
    title: "X-Ray Tube",
    questions: [
      {
        q: "Which are the four major components of an X-ray tube?",
        opts: ["Filament, focusing cup, target, housing", "Cathode, anode, glass envelope, protective housing", "Rotor, stator, target, window", "Transformer, rectifier, filament, anode"],
        ans: 1
      },
      {
        q: "Thermionic emission in the X-ray tube filament occurs when current reaches approximately:",
        opts: ["1 A", "2 A", "4 A and above", "10 A"],
        ans: 2
      },
      {
        q: "Filaments are made of thoriated tungsten. Adding 1-2% thorium serves to:",
        opts: ["Increase the melting point only", "Increase efficiency of thermionic emission and prolong tube life", "Reduce the size of the focal spot", "Decrease heat generation"],
        ans: 1
      },
      {
        q: "The focusing cup in the X-ray tube cathode is negatively charged in order to:",
        opts: ["Attract electrons toward the cathode", "Condense the electron beam to a small area of the anode called the focal spot", "Increase the tube current", "Cool the filament"],
        ans: 1
      },
      {
        q: "A patient requires high tube current for a chest X-ray. Which filament should be used?",
        opts: ["Small filament", "Large filament", "Either filament, they are identical", "A tungsten wire outside the tube"],
        ans: 1
      },
      {
        q: "Rotating anodes in general purpose X-ray tubes rotate at what standard speed?",
        opts: ["1,200 rpm", "3,200 rpm", "5,000 rpm", "10,000 rpm"],
        ans: 1
      },
      {
        q: "What is the main advantage of rotating anodes over stationary anodes?",
        opts: ["They are cheaper to manufacture", "They prevent any single spot from receiving successive electron pulses, preventing anode damage", "They eliminate the need for a focusing cup", "They reduce the kVp required"],
        ans: 1
      },
      {
        q: "Which of the following is NOT a reason tungsten is used as the target material?",
        opts: ["High atomic number (74)", "High melting point (3410°C)", "Low cost compared to all other metals", "Thermal conductivity nearly equal to copper"],
        ans: 2
      },
      {
        q: "The line focus principle refers to:",
        opts: ["Aligning the anode with the cathode in a straight line", "Angling the anode target so the effective focal spot is smaller than the actual focal spot", "Using multiple filaments to focus the electron beam", "Placing the grid parallel to the X-ray beam"],
        ans: 1
      },
      {
        q: "The most common target angle used in diagnostic radiography is:",
        opts: ["5 degrees", "12 degrees", "25 degrees", "45 degrees"],
        ans: 1
      },
      {
        q: "As the anode angle decreases, which of the following occurs?",
        opts: ["The effective focal spot becomes larger and image detail worsens", "The effective focal spot appears smaller, enhancing image detail", "The anode heel effect decreases", "The actual focal spot increases in size"],
        ans: 1
      },
      {
        q: "The anode heel effect causes a decrease in X-ray beam intensity from:",
        opts: ["Anode to cathode direction", "Cathode to anode direction", "Center to periphery", "Left to right"],
        ans: 1
      },
      {
        q: "When imaging a thick body part using the anode heel effect, the cathode side should be placed over:",
        opts: ["The thinner area because it needs less penetration", "The area of greatest density as it has the most penetrating beam", "The edge of the patient", "The area closest to the image receptor"],
        ans: 1
      },
      {
        q: "Decreasing the anode angle results in which combination?",
        opts: ["Smaller focal spot and smaller anode heel effect", "Larger focal spot and larger anode heel effect", "Smaller focal spot and larger anode heel effect", "Larger focal spot and smaller anode heel effect"],
        ans: 2
      },
      {
        q: "The glass envelope of the X-ray tube is usually made of Pyrex glass primarily because:",
        opts: ["Pyrex is transparent to X-rays", "Pyrex can withstand tremendous heat", "Pyrex is cheaper than other materials", "Pyrex has a low atomic number"],
        ans: 1
      },
      {
        q: "The protective housing of the X-ray tube contains oil that serves as:",
        opts: ["A lubricant for the rotating anode only", "Both an electrical insulator and a thermal cushion", "A contrast medium for imaging", "A filter for low-energy X-rays"],
        ans: 1
      }
    ]
  },
  {
    lecture: 4,
    title: "X-Ray Tube Failure",
    questions: [
      {
        q: "Which of the following is NOT listed as a common cause of X-ray tube failure?",
        opts: ["Extremely high voltage", "Excessive heat generation", "Improper patient positioning", "Rough handling"],
        ans: 2
      },
      {
        q: "Cracking of the X-ray tube housing is caused by:",
        opts: ["Vaporization of the filament", "Expansion of air and oil inside, increasing internal pressure", "Loss of vacuum in the glass envelope", "Pitting of the anode surface"],
        ans: 1
      },
      {
        q: "Radiation leakage from the X-ray tube housing should not exceed:",
        opts: ["10 mR/hr", "50 mR/hr", "100 mR/hr", "500 mR/hr"],
        ans: 2
      },
      {
        q: "Loss of vacuum in the glass envelope results in:",
        opts: ["Improved X-ray output quality", "Production of secondary electrons and uncontrollable X-ray production", "Reduced heat generation", "Longer tube life"],
        ans: 1
      },
      {
        q: "The recommended remedy for preventing glass envelope faults caused by differences in expansion coefficients is to:",
        opts: ["Use special alloys with the same coefficients of linear expansion as Pyrex glass", "Replace the glass with metal", "Reduce the kVp used", "Increase cooling oil volume"],
        ans: 0
      },
      {
        q: "Filament vaporization is caused by:",
        opts: ["Using too low a tube current", "Excessive heating of the filament for longer periods", "Loss of vacuum in the tube", "Kinking of the anode target"],
        ans: 1
      },
      {
        q: "To prevent filament vaporization, tungsten is mixed with 1-2% thorium. What does this achieve?",
        opts: ["Increases the filament resistance", "Reduces the risk of vaporization and breakage of the filament", "Increases the melting point of tungsten only", "Reduces the electron emission efficiency"],
        ans: 1
      },
      {
        q: "Kinking of the anode target material results in:",
        opts: ["Increased X-ray output", "Distortion of anode angle, narrowing of beam, and greater geometric unsharpness", "Improved image contrast", "Reduced patient dose"],
        ans: 1
      },
      {
        q: "Which alloy addition helps prevent kinking of the anode target?",
        opts: ["10% Rhenium added to 90% tungsten", "5% Thorium added to 95% tungsten", "20% Molybdenum added to 80% tungsten", "15% Copper added to 85% tungsten"],
        ans: 0
      },
      {
        q: "Roughening and pitting of the anode surface results in:",
        opts: ["Increased X-ray output and improved image quality", "Scattering and absorption of X-rays, leading to diminished X-ray output", "Better heat dissipation", "Longer tube life"],
        ans: 1
      },
      {
